# Copy to /etc/nids/nids.env and edit for your deployment.

# Interface to sniff. On the LXC this is usually eth0. To monitor the WHOLE
# network (not just this box) you must feed it mirrored traffic — see README.
IDS_INTERFACE=eth0

# BPF capture filter. By default we exclude the dashboard port so the IDS does
# not capture and re-scan its own alert/API traffic (a self-feedback loop where
# rule strings in API responses re-trigger alerts). On a dedicated SPAN/mirror
# interface where the mgmt plane is separate, you can clear this.
IDS_BPF_FILTER=not port 8080
# Example also excluding your SSH management traffic:
# IDS_BPF_FILTER=not port 8080 and not port 22

# Web dashboard bind
IDS_HOST=0.0.0.0
IDS_PORT=8080

# Set to true to run synthetic demo traffic instead of real capture.
IDS_DEMO=false

# Paths (data dir is bind-mounted from TrueNAS in the recommended setup)
IDS_DB_PATH=/opt/nids/data/ids.db
IDS_RULES_PATH=/opt/nids/rules/default.rules.json

# Daily rollover: at this local hour (0-23) the day's activity is written to a
# log file under IDS_LOG_DIR and the live stats reset for a fresh day.
IDS_ROLLOVER_HOUR=23
IDS_LOG_DIR=/opt/nids/data/logs
